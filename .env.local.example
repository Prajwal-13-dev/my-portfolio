# GitHub ingestion (Zero-Touch Sync)
# Fine-grained PAT, read-only "Public Repositories" access is enough.
# github.com/settings/tokens -> Generate new token (fine-grained)
GITHUB_TOKEN=
GITHUB_USERNAME=Prajwal-13-dev

# Public NEXT_PUBLIC_ copy is needed client-side for shields.io badge URLs.
NEXT_PUBLIC_GITHUB_USERNAME=Prajwal-13-dev

# Supabase project (app.supabase.com -> New project -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for POST /api/revalidate?secret=... to manually bust the
# GitHub project cache without waiting for the hourly revalidation window.
REVALIDATE_SECRET=
